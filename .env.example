# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Flask ────────────────────────────────────────────────
FLASK_SECRET_KEY=your-strong-random-secret-key-here
PORT=5000

# ── PostgreSQL (Supabase direct connection) ──────────────
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# Service-role key (backend only — never expose to browser)
SUPABASE_SECRET_KEY=your-supabase-service-role-key
# Anon/publishable key (used by backend set_session endpoint)
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# ── AI ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Next.js (frontend — baked into client bundle at build time) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=your-supabase-anon-key

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Defaults to http://localhost:3000 if not set.
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://example.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Scoring engine (optional) ────────────────────────────
# Set to "embeddings" to use Gemini embedding scoring, or leave as "legacy" for LSA
SCORING_ENGINE=legacy
